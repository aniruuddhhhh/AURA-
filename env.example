# .env.example
# ═══════════════════════════════════════════════════════════════════
# AURA Environment Variables Template
# ═══════════════════════════════════════════════════════════════════
#
# INSTRUCTIONS:
# 1. Copy this file to .env:  cp .env.example .env
# 2. Replace the placeholder values with your actual API keys
# 3. NEVER commit the .env file to Git!
#
# ═══════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────
# REQUIRED: Gemini API Key
# ───────────────────────────────────────────────────────────────────
# Get your free API key from: https://aistudio.google.com/apikey
# Used for: AI insights, translation, SQL generation

GEMINI_API_KEY=your_gemini_api_key_here


# ───────────────────────────────────────────────────────────────────
# OPTIONAL: Other API Keys
# ───────────────────────────────────────────────────────────────────

# OpenAI API Key (if you want to use GPT models)
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (if you want to use Claude)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here


# ───────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ───────────────────────────────────────────────────────────────────

# User ID for filtering data (default: 1503960366)
CURRENT_USER_ID=1503960366

# Database file paths
SQL_DB_PATH=aura_health.db
SESSION_DB_PATH=aura_session.db
VECTOR_DB_DIR=./aura_vector_db_hf


# ───────────────────────────────────────────────────────────────────
# MODEL CONFIGURATION
# ───────────────────────────────────────────────────────────────────

# Embedding model for vector search
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM model for insights (if using local models)
# LLM_MODEL=llama3.2


# ───────────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ───────────────────────────────────────────────────────────────────

# Enable debug mode (prints more logs)
DEBUG_MODE=False

# Enable multilingual features
MULTILINGUAL_ENABLED=True

# Enable voice transcription
VOICE_ENABLED=True


# ───────────────────────────────────────────────────────────────────
# NOTES
# ───────────────────────────────────────────────────────────────────
#
# - Make sure .env is in your .gitignore file
# - Don't share your API keys publicly
# - Regenerate keys if accidentally exposed
# - Use environment-specific .env files (.env.dev, .env.prod)
#
# ═══════════════════════════════════════════════════════════════════
